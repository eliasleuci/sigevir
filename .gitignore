# Environment variables
.env
.env.local
.env.*.local

# Node modules
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store

# Build output
dist/
build/
out/

# Runtime
tmp/
logs/
*.log

# OS
.DS_Store
Thumbs.db

# Backend specific
backend/node_modules/
backend/dist/
backend/.env
backend/.env.local

# Frontend specific
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# Testing
coverage/
.nyc_output/

# Database
*.sqlite
*.db

# Misc
.env.example
.eslintcache
.prettierignore
